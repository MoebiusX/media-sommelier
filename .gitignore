# deps
node_modules/
.pnp.*
.yarn/*

# build
dist/
build/
out/
*.tsbuildinfo

# desktop packaging
src-tauri/target/
release/

# local data / caches (never commit a user's catalog or enrichment cache)
*.sqlite
*.sqlite-*
*.db
data/
cache/
.env
.env.local

# e2e: generated fixtures + seeded catalog (the specs/config/seed ARE committed; the .tmp artifacts are not)
e2e/.tmp/
test-results/
playwright-report/
playwright/.cache/

# vendored native binaries (fetched via tools/fetch-fpcalc; not committed)
vendor/

# local-only scratch tools (underscore-prefixed) — may reference a user's drive paths; never commit
tools/_*

# os / editor
.DS_Store
Thumbs.db
.idea/
.vscode/*
!.vscode/extensions.json
