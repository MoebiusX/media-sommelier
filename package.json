{
  "name": "media-sommelier",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "description": "Reconstruct scattered media collections into usable albums/events. Originals never mutated.",
  "engines": {
    "node": ">=22"
  },
  "bin": {
    "sommelier": "dist/cli/index.js"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "cli": "tsx src/cli/index.ts",
    "ui": "tsx src/server/index.ts",
    "dev": "concurrently -n api,web -c yellow,cyan \"npm:dev:api\" \"npm:dev:web\"",
    "dev:api": "tsx watch src/server2/index.ts",
    "dev:web": "npm --prefix web run dev",
    "build:web": "npm --prefix web run build",
    "ingest": "tsx src/server2/ingest.ts",
    "reconstruct:sample": "tsx src/cli/index.ts reconstruct test/fixtures/sample/sample-collection.dir.txt --from-listing"
  },
  "dependencies": {
    "better-sqlite3": "^12.11.1",
    "exifr": "^7.1.3",
    "ffmpeg-static": "^5.3.0",
    "ffprobe-static": "^3.1.0",
    "music-metadata": "^10.6.0",
    "node-taglib-sharp": "^6.0.3"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^22.9.0",
    "concurrently": "^10.0.3",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3",
    "vitest": "^2.1.5"
  }
}
